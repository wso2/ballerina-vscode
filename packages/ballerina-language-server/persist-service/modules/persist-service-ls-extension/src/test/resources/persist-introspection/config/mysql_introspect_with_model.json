{
  "description": "MySQL database introspection - marks tables as selected and existing when they match records in the model file",
  "testProjectFolder": "sample-project-with-model",
  "data": {
    "metadata": {
      "label": "testdb",
      "description": "mysql connection"
    },
    "properties": {
      "dbSystem": {
        "metadata": {
          "label": "Database System",
          "description": "The database system type (e.g., mysql, postgresql, mssql)"
        },
        "value": "mysql",
        "enabled": true,
        "editable": true,
        "optional": false,
        "advanced": false
      },
      "host": {
        "metadata": {
          "label": "Host",
          "description": "Database server host address"
        },
        "value": "localhost",
        "enabled": true,
        "editable": true,
        "optional": false,
        "advanced": false
      },
      "port": {
        "metadata": {
          "label": "Port",
          "description": "Database server port number"
        },
        "value": "3307",
        "enabled": true,
        "editable": true,
        "optional": false,
        "advanced": false
      },
      "user": {
        "metadata": {
          "label": "User",
          "description": "Database username"
        },
        "value": "root",
        "enabled": true,
        "editable": true,
        "optional": false,
        "advanced": false
      },
      "password": {
        "metadata": {
          "label": "Password",
          "description": "Database user password"
        },
        "value": "Test123#",
        "enabled": true,
        "editable": true,
        "optional": false,
        "advanced": false
      },
      "database": {
        "metadata": {
          "label": "Database",
          "description": "Name of the database to connect"
        },
        "value": "testdb",
        "enabled": true,
        "editable": true,
        "optional": false,
        "advanced": false
      }
    },
    "modelFilePath": "persist/model.bal"
  },
  "output": {
    "tables": [
      {"table": "employees", "selected": true, "existing": true},
      {"table": "departments", "selected": true, "existing": true},
      {"table": "projects", "selected": false, "existing": false},
      {"table": "no_pk_table", "selected": false, "existing": false}
    ]
  }
}
